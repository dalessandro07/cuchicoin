# =============================================================================
# KuchiCoin — environment variables
# Copy to `.env` for local development. Never commit real secrets.
# =============================================================================

# --- Client (embedded in the JS/APK bundle) ---------------------------------
# Public HTTPS origin of the deployed Expo API (auth + finance routes).
# Leave empty / unset for local `npx expo start` (defaults to localhost:8081).
# Required for production/preview APK builds.
EXPO_PUBLIC_API_URL=https://kuchicoin.expo.app

# --- Server only (EAS Hosting / Node host — NEVER prefix with EXPO_PUBLIC_) -
# Turso database
TURSO_URL=libsql://YOUR_DB.turso.io
TURSO_AUTH_TOKEN=

# Better Auth — must match the public API origin in production
BETTER_AUTH_URL=https://kuchicoin.expo.app
BETTER_AUTH_SECRET=generate-a-long-random-string

# Optional comma-separated extra trusted origins for Better Auth
# TRUSTED_ORIGINS=https://your-web.expo.app

# Optional: EAS project id (also set via `eas init`)
# EAS_PROJECT_ID=

# FreeLLM — receipt OCR + assistant chat/TTS (server only; set also in EAS Hosting secrets)
FREELLM_API_KEY=
FREELLM_BASE_URL=https://freellmapi.alessandrorios.com/v1
# Optional text model (omit / "auto" → FreeLLM auto-route)
# FREELLM_TEXT_MODEL=
# Optional TTS model for assistant voice confirmations (POST /audio/speech)
# FREELLM_SPEECH_MODEL=
