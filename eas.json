{
	"cli": {
		"version": ">= 16.0.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"environment": "development",
			"android": {
				"buildType": "apk"
			}
		},
		"preview": {
			"distribution": "internal",
			"environment": "preview",
			"android": {
				"buildType": "apk"
			},
			"env": {
				"EXPO_PUBLIC_API_URL": "https://kuchicoin.expo.app"
			}
		},
		"production": {
			"environment": "production",
			"android": {
				"buildType": "apk"
			},
			"env": {
				"EXPO_PUBLIC_API_URL": "https://kuchicoin.expo.app"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
